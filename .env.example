# LLM Provider
LLM_PROVIDER=groq

# Groq API Key (get one at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

GEMINI_API_KEY=your_gemini_api_key_here

# Knowledge Base
KB_PATH=./knowledge_base

# Retrieval settings
MAX_SEARCH_RESULTS=8
MAX_PAGES_PER_QUERY=8
CACHE_TTL_HOURS=24

# Tavily search API (optional but strongly recommended for better results)
# Free tier: 1 000 searches/month — https://app.tavily.com
# When set, Tavily is used as the primary search engine (returns pre-cleaned
# page content, so many pages don't need scraping at all).
# Leave blank to fall back to DuckDuckGo.
TAVILY_API_KEY=

# Cross-encoder re-ranking via flashrank (no GPU required)
# Improves which retrieved chunks reach the LLM.
# Set to false to disable (saves ~200 ms per query on slow machines).
USE_RERANKER=true

# LLM-based document pre-processing
# Strips navigation/boilerplate from scraped pages and keeps only
# visa-relevant content before storing in the knowledge base.
# Adds ~1-2 s per page, but RAG quality improves significantly.
PREPROCESS_DOCS=true
